{
  "name": "fastify-template",
  "version": "1.0.1",
  "description": "A modern Fastify TypeScript backend template with TypeBox validation, Drizzle ORM, built-in security plugins, and RESTful API design following GitHub API conventions.",
  "main": "app.ts",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "tsx watch --env-file=.env ./src/server.ts",
    "test": "c8 -r=text -r=html -r=lcov glob -c \"tsx --test --test-concurrency=1\" \"./test/**/*.ts\"",
    "lint": "eslint --ignore-pattern=dist",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier . --list-different",
    "format-fix": "prettier . --write",
    "util:hash": "tsx ./scripts/hash-password.ts",
    "db:create": "tsx --env-file=.env ./scripts/create-database.ts",
    "db:seed": "tsx --env-file=.env ./scripts/seed-database.ts",
    "db:types": "kysely-codegen --dialect postgres --env-file .env"
  },
  "keywords": [
    "fastify",
    "typescript",
    "template",
    "boilerplate",
    "backend",
    "api",
    "rest",
    "restful",
    "typebox",
    "kysely",
    "sqlite"
  ],
  "author": "Pony",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@sinclair/typebox": "^0.34.48",
    "close-with-grace": "^2.5.0",
    "fastify": "^5.8.4",
    "fastify-favicon": "^5.0.0",
    "fastify-ip": "^2.0.0",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.14",
    "neverthrow": "^8.2.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "22.13.14",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fastify-tsconfig": "^3.0.0",
    "glob-bin": "^1.1.0",
    "kysely-codegen": "^0.20.0",
    "neostandard": "^0.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
